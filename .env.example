# Arquivo .env.example
# Copie este arquivo para .env e customize com suas informações

# ============================================
# CONFIGURAÇÕES DO BACKEND (ASP.NET Core)
# ============================================

# Ambiente de execução
ASPNETCORE_ENVIRONMENT=Development

# Porta do servidor
Port=5000

# ============================================
# AUTENTICAÇÃO
# ============================================

# Credenciais padrão para login
Auth__Username=demo
Auth__Password=demo123

# ============================================
# JWT (JSON Web Token)
# ============================================

# Chave secreta para assinar tokens (mínimo 32 caracteres)
# IMPORTANTE: Mudar em produção!
Jwt__Secret=sua_chave_secreta_super_segura_e_longa_aqui_minimo_32_caracteres

# Tempo de expiração do token em minutos
Jwt__ExpireMinutes=60

# Emissor e público do token
Jwt__Issuer=KylyProductsAPI
Jwt__Audience=KylyProductsWeb

# ============================================
# DADOS
# ============================================

# Caminho para os arquivos de dados
DataPath__BasePath=.

# ============================================
# LOGGING
# ============================================

# Nível de logging (Debug, Information, Warning, Error)
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft=Warning

# ============================================
# CONFIGURAÇÕES DO FRONTEND (React)
# ============================================

# URL da API backend
VITE_API_URL=http://localhost:5000

# Modo de ambiente
VITE_MODE=development

# ============================================
# DOCKER
# ============================================

# Versão do .NET
DOTNET_VERSION=7.0

# Versão do Node.js
NODE_VERSION=18

# ============================================
# NOTAS IMPORTANTES
# ============================================

# 1. NÃO use este arquivo em produção
# 2. Use secrets management (Azure Key Vault, etc)
# 3. Mude Jwt__Secret em produção
# 4. Nunca commite arquivo .env com valores reais
# 5. Use .env.example para documentação
